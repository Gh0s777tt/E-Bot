{
  "name": "bot-dc",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "sync": "node ingest/sync.mts",
    "sync:cloud": "node ingest/sync.mts && node dashboard/scripts/seed-supabase.mts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "docs:check": "node scripts/check-docs-sync.mjs",
    "typecheck": "pnpm -r --if-present exec tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "vitest": "^4.1.8"
  }
}
