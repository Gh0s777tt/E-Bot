# =====================================================================
#  Bot DC — szablon zmiennych środowiskowych
#  Skopiuj do .env i uzupełnij wartościami:  cp .env.example .env
#  NIGDY nie commituj .env (jest w .gitignore).
# =====================================================================

# ── DISCORD (wymagane) ──
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=
DISCORD_DEV_GUILD_ID=
NOTIFY_DISCORD_CHANNEL_ID=
NOTIFY_MENTION=
YOUTUBE_LIVE_CHANNEL_ID=
NOTIFY_YOUTUBE_INTERVAL_SEC=0

# ── Integracja GH0ST EMPIRE (/link) ──
# GHOST_API_URL — URL zewnętrznego portalu GH0ST (Tokens / ekonomia GT). Puste → integracja wyłączona
# (panel pokazuje instrukcję /link, ekonomia GT niedostępna). Ustaw na własny portal.
GHOST_API_URL=
GHOST_BOT_SECRET=

# ── GameVault (web/) — sekret admina do zapisu ustawień powiadomień ──
# Wymagany do POST /api/settings (zapis notify_* do współdzielonej bot.db). Bez niego zapis = 401 (fail-closed).
# Uprawnienia zaproszenia bota: opcjonalny DISCORD_BOT_PERMISSIONS (bitfield); domyślnie 8 = Administrator.
WEB_ADMIN_SECRET=

# ── TWITCH / IGDB ──
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_CLIENT_ID=
TWITCH_BOT_CLIENT_SECRET=
TWITCH_CHANNEL=
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── KICK ──
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_BOT_CLIENT_ID=
KICK_BOT_CLIENT_SECRET=
KICK_CHANNEL=

# ── YOUTUBE ──
YOUTUBE_API_KEY=
YOUTUBE_BOT_CLIENT_ID=
YOUTUBE_BOT_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL=

# ── RUMBLE ──
RUMBLE_LIVESTREAM_API_URL=

# ── MEDAL ──
MEDAL_API_KEY=

# ── X / TWITTER ──
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── STEAM ──
STEAM_WEB_API_KEY=
STEAM_ID64=

# ── PLAYSTATION ──
PSN_NPSSO=

# ── AI ──
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# ── DANE ──
DATABASE_URL=file:./data/bot.db
REDIS_URL=

# ── INFRA / DEVOPS ──
GITHUB_TOKEN=
GITHUB_FINEGRAINED_TOKEN=
VERCEL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SNYK_TOKEN=
GITGUARDIAN_TOKEN=

# Faza 7 / F10.3 — Sentry (śledzenie błędów). Opcjonalne: wklej DSN z sentry.io, by aktywować
# raportowanie błędów bota i panelu (bez DSN moduł jest uśpiony). Ten sam klucz w .env (Railway) i Vercel.
SENTRY_DSN=

# Monitoring / uptime / cron (Faza 6 / B7). Endpointy ISTNIEJĄ w panelu — to tylko ich wiring/ochrona.
# Pełny przewodnik wdrożenia (Railway + Vercel + cron-job.org + Uptime.com): docs/AKTYWACJA-DEPLOY.md.
#  • /api/health        — publiczny healthcheck (200 gdy puls bota świeży <120 s, 503 gdy nie) → Uptime.com.
#  • /api/health/check  — cron alarmujący na Discord przy ZMIANIE down/up (dedup) → cron-job.org.
#  • CRON_SECRET        — opcjonalna ochrona /api/health/check (nagłówek `Bearer <secret>` albo `?key=<secret>`).
#  • BOT_STATUS_URL     — opcjonalnie: jeśli bot wystawia własny status HTTP, panel czyta go zamiast Supabase.
CRON_SECRET=
BOT_STATUS_URL=

# Marketplace M4 — self-serve multi-tenant. '1' = admini serwerów (MANAGE_GUILD) mogą logować się
# do panelu i zarządzać SWOIM serwerem (izolacja per-guild). Puste/0 = panel jednowłaścicielski
# (tylko DASHBOARD_OWNER_IDS + staff). Włączenie dodaje scope `guilds` do OAuth Discorda.
MARKETPLACE_SELF_SERVE=

# Uprawnienia bota w linku zaproszenia (onboarding „dodaj bota"). Domyślnie 8 (Administrator).
# Zawęź wg potrzeb (bitfield uprawnień Discorda); puste = 8.
DISCORD_BOT_PERMISSIONS=

# Marketplace M5 — billing Stripe (tiery premium). Puste = billing UŚPIONY (zero paywalla).
# Przewodnik: docs/AKTYWACJA-STRIPE.md. Klucze ustaw w env Vercel — NIGDY w repo/czacie.
#  • STRIPE_SECRET_KEY    — klucz sekretny (sk_...). Po wycieku NATYCHMIAST zrotuj w Stripe.
#  • STRIPE_PRICE_ID      — ID ceny subskrypcji premium (price_...).
#  • STRIPE_WEBHOOK_SECRET — sekret webhooka (whsec_..., z konfiguracji endpointu).
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Marketplace M6 — community pluginy 3rd-party. '1' = zalogowani mogą ZGŁASZAĆ pluginy (trafiają
# do moderacji jako 'pending'; zatwierdza właściciel/staff). Puste/0 = brak przyjmowania zgłoszeń.
# Wykonanie zatwierdzonego pluginu (sandbox webhook-first) działa przez panel — owner-run oraz
# auto-trigger z bota (poniżej PLUGIN_BRIDGE_*). Obcy kod NIE działa w procesie bota.
# Pełny przewodnik (aktywacja + kontrakt webhooka + przykładowy plugin): docs/AKTYWACJA-COMMUNITY.md.
MARKETPLACE_COMMUNITY=

# Marketplace M6 most bot→panel — auto-trigger pluginów community na zdarzenia Discorda (np. wejście
# członka). Domyślnie WYŁĄCZONE: ustaw OBA, aby aktywować (bez nich bot nie forwarduje zdarzeń).
#  • PLUGIN_BRIDGE_URL    — baza panelu (TYLKO https, np. https://e-bot-dc.vercel.app). Bot POST-uje
#                           na {URL}/api/internal/plugin-event.
#  • PLUGIN_BRIDGE_SECRET — współdzielony sekret (≥16 znaków) — TEN SAM w env bota i panelu (Vercel).
#                           Po wycieku natychmiast zrotuj. Endpoint bez sekretu zwraca 404.
PLUGIN_BRIDGE_URL=
PLUGIN_BRIDGE_SECRET=

# ── SUPABASE (chmura — WYMAGANE dla panelu i synchronizacji configu bota) ──
# Bez tych panel/chmura NIE wystartują (hasSupabase=false → funkcje cloud no-op).
# service_role OMIJA RLS — trzymaj WYŁĄCZNIE server-side, nigdy w kliencie. Po wycieku natychmiast zrotuj.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Publiczne (eksponowane do klienta) — fallback realtime/anon. Zwykle te same wartości co URL/ANON wyżej.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── PANEL / AUTH (dashboard) ──
# AUTH_SECRET — podpis sesji (HMAC), ≥16 znaków, w prod WYMAGANY (fail-closed). Generuj: openssl rand -hex 32
AUTH_SECRET=
# DASHBOARD_OWNER_IDS — discord_id właścicieli panelu po przecinku (pełny dostęp instance-admin).
DASHBOARD_OWNER_IDS=
# DASHBOARD_URL — publiczny URL panelu (np. https://e-bot-dc.vercel.app); m.in. onboarding bota.
DASHBOARD_URL=
# NEXT_PUBLIC_DASHBOARD_URL — publiczny URL panelu wystawiony do PRZEGLĄDARKI (Next inlinuje przy
# buildzie). Buduje URL-e webhooków pokazywane w panelu (Ko-fi, webhook-relay). Pusty → panel użyje
# window.location.origin (działa na dowolnej domenie bez konfiguracji).
NEXT_PUBLIC_DASHBOARD_URL=
# DASHBOARD_ALLOWED_HOSTS — (opcjonalne, hardening) dozwolone hosty panelu po przecinku (np.
# e-bot-dc.vercel.app). Ustawione → OAuth redirect_uri budowany TYLKO z tych hostów (anty host-header
# poisoning). Puste = bez egzekwowania (zachowanie domyślne).
DASHBOARD_ALLOWED_HOSTS=

# ── BOT — runtime / konfiguracja ──
# DATABASE_PATH — lokalna baza SQLite bota (domyślnie ./data/bot.db).
DATABASE_PATH=
# LOG_LEVEL — debug | info | warn | error (domyślnie info).
LOG_LEVEL=
# PRESENCE_INTENT — '1' włącza intent obecności (role z aktywności/streamingu).
PRESENCE_INTENT=
# SHARD_COUNT — liczba shardów lub 'auto' (skala >2500 serwerów); puste = bez shardingu.
SHARD_COUNT=
# DISCORD_GUILD_ID — jawny serwer dla panelu (snowflake); puste = pierwszy dostępny.
DISCORD_GUILD_ID=
# GHOST_GUILD_ID / GHOST_ECONOMY — serwer GH0ST EMPIRE + przełącznik ekonomii EMPIRE ('1').
GHOST_GUILD_ID=
GHOST_ECONOMY=

# ── INTEGRACJE opcjonalne (klucze API) ──
# ITAD_API_KEY — IsThereAnyDeal (darmówki + tracker cen). CAT_API_KEY — thecatapi.com (/cat).
ITAD_API_KEY=
CAT_API_KEY=
# GOG_GALAXY_DB — ścieżka do bazy GOG Galaxy (kolektor ingest/gog).
GOG_GALAXY_DB=

# ── TWITCH EventSub (sub→rola — opcjonalne, patrz docs/AKTYWACJA-TWITCH-SUB.md) ──
# TWITCH_EVENTSUB_SECRET — sekret podpisu webhooka. EVENTSUB_CALLBACK — publiczny URL callbacku (https).
# TWITCH_USER_TOKEN — OAuth broadcastera (scope channel:read:subscriptions).
TWITCH_EVENTSUB_SECRET=
EVENTSUB_CALLBACK=
TWITCH_USER_TOKEN=

# ── INTERWAŁY pollingu powiadomień LIVE (sekundy; puste = domyślne) ──
NOTIFY_TWITCH_INTERVAL_SEC=
NOTIFY_KICK_INTERVAL_SEC=
NOTIFY_RUMBLE_INTERVAL_SEC=
