// Builder slash-komendy z metodą setDescriptionLocalizations (feature-detect — typ Command
// w index.mts opisuje tylko { name, toJSON }).
type LocalizableBuilder = {
  name?: string;
  setDescriptionLocalizations?: (m: Record<string, string>) => unknown;
};

// Wpina opisy w językach Discorda do każdego buildera (mutuje data in-place przed toJSON()).
// Idempotentne. 'pl' pomijamy (to opis domyślny buildera), 'ar' nie ma kodów Discorda → pomijany.
export function applyCommandLocalizations(commands: ReadonlyArray<{ data: unknown }>): void {
  for (const cmd of commands) {
    const data = cmd.data as LocalizableBuilder;
    const name = data?.name;
    if (!name || typeof data.setDescriptionLocalizations !== 'function') continue;

    const map: Record<string, string> = {};
    for (const locale of LOCALES) {
      if (locale === 'pl') continue;
      const text = COMMAND_DESC[locale]?.[name];
      if (!text) continue;
      const clamped = text.length > DISCORD_DESC_MAX ? text.slice(0, DISCORD_DESC_MAX) : text;
      for (const dl of LOCALE_TO_DISCORD[locale]) map[dl] = clamped;
    }
    if (Object.keys(map).length) data.setDescriptionLocalizations(map);
  }
}
