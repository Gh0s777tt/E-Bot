#!/bin/sh
# Pre-commit: pilnuje synchronizacji dokumentacji ‚ÜĒ CHANGELOG (scripts/check-docs-sync.mjs).
# Aktywacja (raz na klon repo):  git config core.hooksPath scripts/hooks
# Pominińôcie awaryjne:           git commit --no-verify
node scripts/check-docs-sync.mjs \
  && node scripts/check-schema-sync.mjs \
  && node scripts/check-env-sync.mjs || {
  echo "" >&2
  echo "‚úó pre-commit: rozjazd synchronizacji (docs‚ÜĒCHANGELOG / _ALL.sql‚ÜĒschematy / .env.example‚ÜĒprocess.env)." >&2
  echo "  ‚Üí Napraw wg komunikatu wyŇľej (markery SYNC / scal tabelńô do _ALL.sql / dodaj klucz do .env.example)." >&2
  echo "  ‚Üí Albo pomiŇĄ awaryjnie: git commit --no-verify" >&2
  exit 1
}
