#!/bin/sh
# Pre-commit: pilnuje synchronizacji dokumentacji ↔ CHANGELOG (scripts/check-docs-sync.mjs).
# Aktywacja (raz na klon repo):  git config core.hooksPath scripts/hooks
# Pominięcie awaryjne:           git commit --no-verify
node scripts/check-docs-sync.mjs \
  && node scripts/check-schema-sync.mjs \
  && node scripts/check-env-sync.mjs || {
  echo "" >&2
  echo "✗ pre-commit: rozjazd synchronizacji (docs↔CHANGELOG / _ALL.sql↔schematy / .env.example↔process.env)." >&2
  echo "  → Napraw wg komunikatu wyżej (markery SYNC / scal tabelę do _ALL.sql / dodaj klucz do .env.example)." >&2
  echo "  → Albo pomiń awaryjnie: git commit --no-verify" >&2
  exit 1
}

# Szybki lint TYLKO plików w indeksie (Biome --staged, bez zapisu — nie zmienia commitu w locie).
pnpm exec biome check --staged --no-errors-on-unmatched || {
  echo "" >&2
  echo "✗ pre-commit: Biome zgłasza błędy w plikach do commitu." >&2
  echo "  → Napraw: pnpm check   (auto-fix)   albo pomiń awaryjnie: git commit --no-verify" >&2
  exit 1
}
